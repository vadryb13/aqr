# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# DuckDB
DUCKDB_PATH=./workspace/aqr.duckdb
FAISS_INDEX_PATH=./workspace/faiss.index

# Backpressure
MAX_QUEUE_DEPTH_SOFT=5000
MAX_QUEUE_DEPTH_HARD=20000

# Workers
N_BACKTEST_WORKERS=10

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Budget
DAILY_BUDGET_USD=50
